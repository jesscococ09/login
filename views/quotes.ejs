<!DOCTYPE html>
<html lang="en">
<%- include("partials/head") %>
<body>

<%- include("partials/nav") %>

<div class="container mt-4">

    <h1 class="text-center mb-4">Quotes</h1>

    <div class="row g-4 justify-content-center">

        <% quotes.forEach(q => { %>
            <div class="col-md-5">
                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <blockquote class="blockquote text-center">
                            <p class="mb-3">"<%= q.quote %>"</p>
                        </blockquote>

                        <div class="d-flex justify-content-center gap-2 mt-3">

                            <a href="/updateQuote?quoteId=<%= q.quoteId %>" class="btn btn-secondary">
                                Update
                            </a>

                            <form action="/deleteQuote/<%= q.quoteId %>" method="POST">
                                <button class="btn btn-danger">Delete</button>
                            </form>

                        </div>

                    </div>

                </div>
            </div>
        <% }) %>

    </div>

    <div class="text-center mt-5">
        <a href="/addQuote" class="btn btn-primary btn-lg px-4">Add Quote</a>
    </div>

</div>

<%- include("partials/footer") %>

</body>
</html>